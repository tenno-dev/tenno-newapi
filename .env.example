# ── Postgres ─────────────────────────────────────────────────────────────────
# Used by the postgres container (POSTGRES_*) AND by the app (DATABASE_URL).
# Keep DATABASE_URL in sync with the three vars below.
POSTGRES_DB=tennodev
POSTGRES_USER=tennodev
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://tennodev:changeme@postgres:5432/tennodev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Blob storage ──────────────────────────────────────────────────────────────
BLOB_BASE_PATH=/app/blob

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
APP_ENV=production

# ── Warframe worldstate ───────────────────────────────────────────────────────
WORLDSTATE_SOURCE_URL=https://content.warframe.com/dynamic/worldState.php
WORLDSTATE_SOURCE_TOKEN=

# ── Web Push — generate keys: npx web-push generate-vapid-keys ───────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Push settings ─────────────────────────────────────────────────────────────
PUSH_ALLOWED_ORIGINS=https://tenno.dev
PUSH_SUBSCRIBE_RATE_LIMIT=30
PUSH_SUBSCRIBE_WINDOW_SECONDS=60
PUSH_ADMIN_TOKEN=

# ── Auth ──────────────────────────────────────────────────────────────────────
DEPLOY_TRIGGER_TOKEN=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://tenno.dev
