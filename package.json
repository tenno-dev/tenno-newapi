{
  "name": "tennodev-api",
  "version": "1.0.0",
  "description": "Tenno New API – Bun + ElysiaJS port",
  "scripts": {
    "start": "bun src/index.ts",
    "start:worker": "bun src/worker.ts",
    "dev": "bun --watch src/index.ts",
    "dev:worker": "bun --watch src/worker.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cron": "^1.2.0",
    "@elysiajs/cors": "^1.2.0",
    "elysia": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "bun-types": "^1.2.0",
    "typescript": "^6.0.3"
  }
}
