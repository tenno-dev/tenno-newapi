:8080 {
    # 1. Authorization check (only for /worldstate)
    @unauthorized {
        path /worldstate
        expression {env.URL_TOKEN} != ""
        not query url={env.URL_TOKEN}
    }
    handle @unauthorized {
        header Content-Type application/json
        respond `{"ok":false,"error":"unauthorized"}` 401
    }

    # 2. Worldstate Proxy
    handle /worldstate {
        rewrite * /cdn/worldState.php
        reverse_proxy https://api.warframe.com {
            header_up Host api.warframe.com
            header_up User-Agent "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36"
            header_up Accept "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8,application/signed-exchange;v=b3;q=0.7"
        }
    }

    # 3. Health Check
    handle /health {
        header Content-Type application/json
        respond `{"ok":true,"service":"warframe-worldstate-proxy"}` 200
    }

    # Fallback
    handle {
        header Content-Type application/json
        respond `{"ok":false,"error":"not found"}` 404
    }
}
